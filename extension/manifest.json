{
  "manifest_version": 3,
  "name": "ResumeDB Autofill Helper",
  "version": "2.0.0",
  "description": "Automatically fill job application forms using your profile and tailored resumes from ResumeDB.",
  "permissions": [
    "sidePanel",
    "tabs",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {},
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
